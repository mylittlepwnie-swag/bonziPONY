# Environment
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node / npm tooling (not part of the Python app)
node_modules/
package.json
package-lock.json

# Editor / tooling / local junk
.claude/
*.lnk
.autoupdate_enabled
